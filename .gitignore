# Dependencies
node_modules/

# Runtime logs (test/prepush output)
*.log
data/*.log

# Backup files
data/*.backup
*.bak

# SQLite runtime database (binary; rebuilt from schema + seed on
# first run if missing).  data/store.json.migrated IS tracked:
# it's the canonical JSON source of truth that can rebuild the DB.
data/store.db
data/store.db-shm
data/store.db-wal

# Environment / secrets
.env.local
.env.*.local
# .env is tracked! It's the canonical local config.
# Use .env.local for personal overrides.
!.env.example

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build artefacts that aren't the deployable UI
# (public-spa/ IS tracked so a fresh clone works without `npm run build`)
public-spa/diagram.html
public/diagram.html
