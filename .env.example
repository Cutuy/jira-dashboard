# ── Server ──────────────────────────────────────────────────
# PORT=3006                              # Dashboard HTTP port

# ── Project ─────────────────────────────────────────────────
JIRA_PROJECT_NAME=my-project             # Display name in header
JIRA_PROJECT_DIR=/path/to/your/project   # Absolute path to your git repo
# JIRA_WORKTREES_DIR=                    # Where git worktrees live (default: <projectDir>/.worktrees)

# ── AI Coder CLI ────────────────────────────────────────────
JIRA_CODER_BIN=opencode                  # Path to your coder binary
JIRA_CODER_TYPE=opencode                 # Backend name in coder.js

# ── Python venv (only if your project uses Python) ─────────
# JIRA_VENV_DIR=.venv                    # Relative to projectDir
# JIRA_PYTHONPATH=src                    # PYTHONPATH relative to projectDir

# ── Testing ─────────────────────────────────────────────────
# JIRA_TEST_CMD=                         # Override auto-detected test command
# JIRA_TEST_TIMEOUT=300000               # Test runner timeout (ms)

# ── Remote editor links ────────────────────────────────────
# REMOTE_HOST=example-claw               # SSH host for VSCode/Cursor URIs

# ── File explorer for diff links ────────────────────────────
# Supports {protocol} {host} {sha} {path} {prefix} {owner} {repo}
# EXPLORER_URL=https://github.com/{owner}/{repo}/blob/{sha}/{path}
# GITHUB_OWNER=my-org
# GITHUB_REPO=my-repo

# ── Close/merge behavior ────────────────────────────────────
# MERGE_STRATEGY=cherry-pick             # cherry-pick or pr

# ── Git ─────────────────────────────────────────────────────
# GIT_DEFAULT_BRANCH=main                # Your repo's main branch name

# ── Database ────────────────────────────────────────────────
# JIRA_DATA_DIR=                         # Override data directory (default: <projectDir>/.jira-dashboard/)
# DB_BUSY_TIMEOUT=5000                   # SQLite busy timeout (ms)
