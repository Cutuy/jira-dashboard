# Server port
# PORT=3006

# Project
JIRA_PROJECT_NAME=my-project
JIRA_PROJECT_DIR=/path/to/your/project
JIRA_WORKTREES_DIR=/path/to/your/project/.worktrees

# Coder CLI tool
JIRA_CODER_BIN=opencode
JIRA_CODER_TYPE=opencode

# Python venv (relative to project dir)
JIRA_VENV_DIR=.venv
JIRA_PYTHONPATH=src

# Test
# JIRA_TEST_CMD=
# JIRA_TEST_TIMEOUT=300000

# Remote hostname for VSCode / Cursor SSH URIs (e.g. "my-dev-box")
# REMOTE_HOST=example-claw

# File explorer URL template — {protocol} {host} {sha} {path} {prefix} {owner} {repo}
# Default: GitHub commit view
# EXPLORER_URL=https://github.com/{owner}/{repo}/blob/{sha}/{path}
# GITHUB_OWNER=my-org
# GITHUB_REPO=my-repo
# Custom: local file explorer
# EXPLORER_URL={protocol}//{host}:18802/explorer/{prefix}/{path}

# Close/merge strategy: cherry-pick (default, merges into default branch) or pr (push + GitHub PR)
# MERGE_STRATEGY=cherry-pick

# Default git branch for checkout / rebase operations (cherry-pick strategy)
# GIT_DEFAULT_BRANCH=main

# SQLite busy timeout in ms
# DB_BUSY_TIMEOUT=5000
